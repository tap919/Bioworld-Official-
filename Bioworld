### src/webviewProvider.ts
```typescript
import * as vscode from 'vscode';
import { Socket } from 'socket.io-client';

export class WebviewViewProvider implements vscode.WebviewViewProvider {
  constructor(private extensionUri: vscode.Uri, private viewId: string, private socketUrl: string) {}

  public resolveWebviewView(webviewView: vscode.WebviewView) {
    webviewView.webview.options = { enableScripts: true, localResourceRoots: [this.extensionUri] };
    webviewView.webview.html = this.getHtmlForView(this.viewId);

    webviewView.webview.onDidReceiveMessage(msg => this.handleMessage(msg));
  }

  private getHtmlForView(viewId: string): string {
    const scripts = `
      <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
      <script src="https://cdn.tailwindcss.com"></script>
      <script>
        const socket = io('${this.socketUrl}');
        socket.on('chatMessage', msg => updateChat(msg));
        socket.on('leaderboardUpdate', ranks => updateLeaderboard(ranks));
        // View-specific logic here
      </script>`;
    return `<body class="bg-gray-900 text-white p-4">${getViewContent(viewId)}${scripts}</body>`;
  }

  private handleMessage(msg: any) {
    // e.g., { cmd: 'joinLab', labId: '123' } → socket.emit
  }
}

function getViewContent(viewId: string): string {
  switch (viewId) {
    case 'dashboard': return '<h1>Stats & Initiatives</h1><div id="leaderboard"></div><div id="chat"></div>';
    case 'labs': return '<h1>Your Labs</h1><ul id="lab-list"></ul>';
    case 'marketplace': return '<h1>Tools & Bounties</h1><div id="market-items"></div>';
    default: return '<h1>BioWorld</h1>';
  }
}
